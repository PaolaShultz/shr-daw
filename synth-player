#!/usr/bin/env bash
set -euo pipefail

APP_NAME="SHR-DAW"
APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/shsynth"
PID_FILE="$STATE_DIR/engine.pid"
LOG_FILE="$STATE_DIR/engine.log"
CURRENT_FILE="$STATE_DIR/current"
RUNTIME_CONFIG="$STATE_DIR/shsynth.conf"
CONTROLLER_CONFIG="$STATE_DIR/controller.conf"

SYNTH_COMMAND=""
CLIENT_NAME=""
MIDI_OUTPUT_MATCH=""
MIDI_INPUT_MATCHES=()
AUDIO_OUTPUTS=()
MIDI_AUTOCONNECT=false
AUDIO_AUTOCONNECT=false
CONFIG_PRESET_DIR=""

DEFAULT_RUNTIME_CONFIG="$APP_DIR/config/shsynth.conf"
if [[ ! -r "$DEFAULT_RUNTIME_CONFIG" ]]; then
  DEFAULT_RUNTIME_CONFIG="$APP_DIR/../share/shsynth/config/shsynth.conf"
fi

load_config() {
  local config_file="$1"
  local key value saw_midi=false saw_audio=false
  [[ -r "$config_file" ]] || return 0
  while IFS='=' read -r key value; do
    key="${key%%#*}"; key="${key//[[:space:]]/}"
    value="${value%%#*}"; value="${value#"${value%%[![:space:]]*}"}"; value="${value%"${value##*[![:space:]]}"}"
    case "$key" in
      synth.command) SYNTH_COMMAND="$value" ;;
      synth.client) CLIENT_NAME="$value" ;;
      presets.directory) CONFIG_PRESET_DIR="$value" ;;
      midi.autoconnect) MIDI_AUTOCONNECT="$value" ;;
      midi.input)
        $saw_midi || { MIDI_INPUT_MATCHES=(); saw_midi=true; }
        [[ -n "$value" ]] && MIDI_INPUT_MATCHES+=("$value")
        ;;
      midi.synth_output) MIDI_OUTPUT_MATCH="$value" ;;
      audio.autoconnect) AUDIO_AUTOCONNECT="$value" ;;
      audio.output)
        $saw_audio || { AUDIO_OUTPUTS=(); saw_audio=true; }
        [[ -n "$value" ]] && AUDIO_OUTPUTS+=("$value")
        ;;
    esac
  done < "$config_file"
}

[[ -r "$DEFAULT_RUNTIME_CONFIG" ]] || {
  printf 'Missing default configuration: %s\n' "$DEFAULT_RUNTIME_CONFIG" >&2
  exit 1
}
load_config "$DEFAULT_RUNTIME_CONFIG"
load_config "$RUNTIME_CONFIG"
if [[ -r "$CONTROLLER_CONFIG" ]]; then
  controller_input="$(sed -n 's/^[[:space:]]*input[[:space:]]*=[[:space:]]*//p' "$CONTROLLER_CONFIG" | tail -n1)"
  [[ -n "$controller_input" ]] && MIDI_INPUT_MATCHES=("$controller_input")
fi
PRESET_DIR="${SHSYNTH_PRESET_DIR:-${CONFIG_PRESET_DIR:-$APP_DIR/presets/synthv1}}"
[[ "$PRESET_DIR" == "~/"* ]] && PRESET_DIR="$HOME/${PRESET_DIR#~/}"
if [[ ! -d "$PRESET_DIR" && -d "$APP_DIR/../share/shsynth/presets/synthv1" ]]; then
  PRESET_DIR="$(cd "$APP_DIR/../share/shsynth/presets/synthv1" && pwd)"
fi

declare -A PRESET_FILE=()
declare -A PRESET_LABEL=()
ORDER=()

load_presets() {
  local file key label index=0
  while IFS= read -r -d '' file; do
    printf -v key 'preset_%03d' "$((++index))"
    label="$(basename "$file" .synthv1)"
    PRESET_FILE["$key"]="$file"
    PRESET_LABEL["$key"]="$label"
    ORDER+=("$key")
  done < <(find "$PRESET_DIR" -type f -name '*.synthv1' -print0 | sort -z)
}

mkdir -p "$STATE_DIR"
load_presets

managed_pid() {
  [[ -r "$PID_FILE" ]] || return 1
  local pid
  read -r pid < "$PID_FILE"
  [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null && printf '%s\n' "$pid"
}

stop_engine() {
  local pid
  if pid="$(managed_pid)"; then
    kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
    for _ in {1..30}; do
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.1
    done
    kill -KILL -- "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
  fi
  rm -f "$PID_FILE" "$CURRENT_FILE"
}

status_text() {
  local pid current midi_status audio_status
  current="$(cat "$CURRENT_FILE" 2>/dev/null || true)"
  if pid="$(managed_pid)"; then
    midi_status="$($MIDI_AUTOCONNECT && printf 'auto: %s' "${MIDI_INPUT_MATCHES[*]}" || printf 'manual')"
    audio_status="$($AUDIO_AUTOCONNECT && printf 'auto: %s' "${AUDIO_OUTPUTS[*]}" || printf 'manual')"
    printf 'Running: %s\nPID: %s\nAudio: %s\nMIDI: %s\n' \
      "${PRESET_LABEL[$current]:-$current}" "$pid" "$audio_status" "$midi_status"
  else
    rm -f "$PID_FILE" "$CURRENT_FILE"
    printf 'SHR-DAW is stopped.\n'
  fi
}

connect_engine() {
  local midi_source="" midi_dest audio_port match destination i
  local audio_outputs=()

  if [[ "$MIDI_AUTOCONNECT" == true ]]; then
    for match in "${MIDI_INPUT_MATCHES[@]}"; do
      midi_source="$(aconnect -l 2>/dev/null | awk -v wanted="${match,,}" 'tolower($0) ~ /^client [0-9]+:/ && index(tolower($0), wanted) {gsub(":", "", $2); print $2; exit}')"
      [[ -n "$midi_source" ]] && break
    done
    midi_dest="$(aconnect -l 2>/dev/null | awk -v wanted="${MIDI_OUTPUT_MATCH,,}" 'tolower($0) ~ /^client [0-9]+:/ && index(tolower($0), wanted) {gsub(":", "", $2); print $2; exit}')"
    if [[ -n "$midi_source" && -n "$midi_dest" ]]; then
      aconnect "$midi_source:0" "$midi_dest:0" 2>/dev/null || true
    fi
  fi

  [[ "$AUDIO_AUTOCONNECT" == true ]] || return 0
  mapfile -t audio_outputs < <(jack_lsp -t -p 2>/dev/null | awk '
    /^[^[:space:]]/ { port=$0; output=0 }
    /properties:.*output/ { output=1 }
    /32 bit float mono audio/ && output && index(port, client ":") == 1 { print port }
  ' client="$CLIENT_NAME")
  for i in "${!AUDIO_OUTPUTS[@]}"; do
    audio_port="${audio_outputs[$i]:-}"
    destination="${AUDIO_OUTPUTS[$i]}"
    [[ -n "$audio_port" ]] && jack_connect "$audio_port" "$destination" 2>/dev/null || true
  done
}

start_preset() {
  local key="$1" preset pid
  preset="${PRESET_FILE[$key]:-}"
  [[ -f "$preset" ]] || { printf 'Unknown or missing synthv1 preset: %s\n' "$key" >&2; return 2; }

  stop_engine
  : > "$LOG_FILE"
  printf '%s\n' "$key" > "$CURRENT_FILE"
  setsid "$SYNTH_COMMAND" --no-gui --client-name "$CLIENT_NAME" "$preset" \
    >>"$LOG_FILE" 2>&1 < /dev/null &
  pid=$!
  printf '%s\n' "$pid" > "$PID_FILE"
  sleep 1
  if ! kill -0 "$pid" 2>/dev/null; then
    printf 'synthv1 failed to start. See %s\n' "$LOG_FILE" >&2
    tail -30 "$LOG_FILE" >&2
    rm -f "$PID_FILE" "$CURRENT_FILE"
    return 1
  fi
  connect_engine
  printf 'Loaded %s.\n' "${PRESET_LABEL[$key]}"
}

list_presets() {
  local key
  for key in "${ORDER[@]}"; do
    printf '%-12s %s\n' "$key" "${PRESET_LABEL[$key]}"
  done
}

terminal_choose() {
  local -n choices_ref=$1
  local count="${#choices_ref[@]}" selected="$2"
  local lines visible top=0 i key rest
  lines="$(tput lines 2>/dev/null || echo 24)"
  (( visible = lines - 3 ))
  (( visible < 4 )) && visible=4

  while true; do
    (( selected < top )) && top=$selected
    (( selected >= top + visible )) && top=$((selected - visible + 1))
    printf '\033[2J\033[H\033[?25l' > /dev/tty
    printf '%s · synthv1\n' "$APP_NAME" > /dev/tty
    printf 'UP/DOWN + ENTER\n\n' > /dev/tty
    for ((i = top; i < count && i < top + visible; i++)); do
      if ((i == selected)); then
        printf '\033[7m  %s\033[0m\n' "${choices_ref[$i]}" > /dev/tty
      else
        printf '  %s\n' "${choices_ref[$i]}" > /dev/tty
      fi
    done
    IFS= read -rsn1 key < /dev/tty || { CHOICE_INDEX=$((count - 1)); break; }
    if [[ "$key" == $'\e' ]]; then
      IFS= read -rsn2 -t 0.1 rest < /dev/tty || rest=""
      key+="$rest"
    fi
    case "$key" in
      $'\e[A'|k) ((selected > 0)) && ((selected--)) || true ;;
      $'\e[B'|j) ((selected + 1 < count)) && ((selected++)) || true ;;
      '') CHOICE_INDEX=$selected; break ;;
      q|Q|$'\e') CHOICE_INDEX=$((count - 1)); break ;;
    esac
  done
  printf '\033[?25h' > /dev/tty
}

menu() {
  command -v whiptail >/dev/null || { printf 'whiptail is required for the playback screen.\n' >&2; return 1; }
  local key selected msg lines cols height width current_index=0
  local choices=()
  for key in "${ORDER[@]}"; do
    choices+=("${PRESET_LABEL[$key]}")
  done
  choices+=("Stop sound" "Exit")

  trap 'printf "\033[?25h" > /dev/tty; stop_engine' EXIT
  trap 'exit 0' INT TERM HUP
  while true; do
    terminal_choose choices "$current_index"
    current_index=$CHOICE_INDEX
    if ((current_index == ${#ORDER[@]})); then
      stop_engine
      continue
    elif ((current_index == ${#ORDER[@]} + 1)); then
      break
    fi

    selected="${ORDER[$current_index]}"
    lines="$(tput lines 2>/dev/null || echo 24)"
    cols="$(tput cols 2>/dev/null || echo 80)"
    (( height = lines > 17 ? 17 : lines - 1 ))
    (( width = cols > 58 ? 58 : cols - 1 ))
    if msg="$(start_preset "$selected" 2>&1)"; then
      whiptail --title "Now playing" --ok-button "Back" --msgbox \
        "$msg\n\nPress ENTER to return to the list." 9 "$width"
    else
      stop_engine
      whiptail --title "Start failed" --scrolltext --msgbox "$msg" "$height" "$width"
    fi
  done
  stop_engine
  printf '\033[?25h' > /dev/tty
  trap - EXIT INT TERM HUP
}

usage() {
  cat <<'EOF'
Usage: synth-player [menu|list|status|start PRESET|stop|log]

With no arguments, opens the synthv1 preset audition menu. Use `list` to see
preset keys. Returning from the Now Playing screen stops and unloads synthv1.
EOF
}

case "${1:-menu}" in
  menu) menu ;;
  list) list_presets ;;
  status) status_text ;;
  start) [[ -n "${2:-}" ]] || { usage; exit 2; }; start_preset "$2" ;;
  stop) stop_engine ;;
  log|logs) tail -n "${2:-80}" "$LOG_FILE" 2>/dev/null || true ;;
  -h|--help|help) usage ;;
  *) usage; exit 2 ;;
esac
